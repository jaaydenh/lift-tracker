{
  "name": "lift-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run --filter @lift-tracker/web dev",
    "build": "bun run --filter @lift-tracker/web build",
